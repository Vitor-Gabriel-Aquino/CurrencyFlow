{
  "info": {
    "_postman_id": "3d6462e0-f168-4f93-9a1d-4fd447f6f3cf",
    "name": "CurrencyFlow",
    "description": "Postman collection for testing the CurrencyFlow API locally. Set access_token after completing the OAuth PKCE flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "frontend_redirect_uri",
      "value": "http://localhost:3000/auth/callback",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "019ec29e-86dc-70bd-9de9-157bc6e2f735",
      "type": "string"
    },
    {
      "key": "code_challenge",
      "value": "",
      "type": "string"
    },
    {
      "key": "code_verifier",
      "value": "",
      "type": "string"
    },
    {
      "key": "authorization_code",
      "value": "",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "payment_request_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Reference Data",
      "item": [
        {
          "name": "List Countries",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/countries",
              "host": ["{{base_url}}"],
              "path": ["api", "countries"]
            }
          }
        },
        {
          "name": "List Currencies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/currencies",
              "host": ["{{base_url}}"],
              "path": ["api", "currencies"]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Employee\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"country_code\": \"BR\",\n  \"preferred_currency_code\": \"BRL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/register",
              "host": ["{{base_url}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user",
              "host": ["{{base_url}}"],
              "path": ["api", "user"]
            }
          }
        },
        {
          "name": "Update Current User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Updated Employee\",\n  \"email\": \"jane.updated@example.com\",\n  \"country_code\": \"BR\",\n  \"preferred_currency_code\": \"BRL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/user",
              "host": ["{{base_url}}"],
              "path": ["api", "user"]
            }
          }
        },
        {
          "name": "Revoke Current Token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tokens/current",
              "host": ["{{base_url}}"],
              "path": ["api", "tokens", "current"]
            }
          }
        }
      ]
    },
    {
      "name": "OAuth PKCE",
      "item": [
        {
          "name": "Open Authorization URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/oauth/authorize?client_id={{client_id}}&redirect_uri={{frontend_redirect_uri}}&response_type=code&scope=profile%3Aread%20profile%3Aupdate%20payments%3Aread%20payments%3Acreate%20payments%3Aapprove&code_challenge={{code_challenge}}&code_challenge_method=S256&state=postman-test",
              "host": ["{{base_url}}"],
              "path": ["oauth", "authorize"],
              "query": [
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{frontend_redirect_uri}}"
                },
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "scope",
                  "value": "profile%3Aread%20profile%3Aupdate%20payments%3Aread%20payments%3Acreate%20payments%3Aapprove"
                },
                {
                  "key": "code_challenge",
                  "value": "{{code_challenge}}"
                },
                {
                  "key": "code_challenge_method",
                  "value": "S256"
                },
                {
                  "key": "state",
                  "value": "postman-test"
                }
              ]
            }
          }
        },
        {
          "name": "Exchange Authorization Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.access_token) pm.collectionVariables.set('access_token', body.access_token);",
                  "if (body.refresh_token) pm.collectionVariables.set('refresh_token', body.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"authorization_code\",\n  \"client_id\": \"{{client_id}}\",\n  \"redirect_uri\": \"{{frontend_redirect_uri}}\",\n  \"code\": \"{{authorization_code}}\",\n  \"code_verifier\": \"{{code_verifier}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/oauth/token",
              "host": ["{{base_url}}"],
              "path": ["oauth", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Payment Requests",
      "item": [
        {
          "name": "Preview Exchange Rate",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/exchange-rate-preview?currency_code=BRL",
              "host": ["{{base_url}}"],
              "path": ["api", "exchange-rate-preview"],
              "query": [
                {
                  "key": "currency_code",
                  "value": "BRL"
                }
              ]
            }
          }
        },
        {
          "name": "Create Payment Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.data && body.data.id) pm.collectionVariables.set('payment_request_id', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Conference reimbursement\",\n  \"description\": \"Hotel and local transportation costs.\",\n  \"amount\": \"123.45\",\n  \"currency_code\": \"BRL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/payment-requests",
              "host": ["{{base_url}}"],
              "path": ["api", "payment-requests"]
            }
          }
        },
        {
          "name": "List Payment Requests",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payment-requests?status=pending&page=1&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "payment-requests"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "15"
                }
              ]
            }
          }
        },
        {
          "name": "Get Payment Request",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payment-requests/{{payment_request_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "payment-requests", "{{payment_request_id}}"]
            }
          }
        },
        {
          "name": "Approve Payment Request",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"review_note\": \"Approved for reimbursement.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/payment-requests/{{payment_request_id}}/approval",
              "host": ["{{base_url}}"],
              "path": ["api", "payment-requests", "{{payment_request_id}}", "approval"]
            }
          }
        },
        {
          "name": "Reject Payment Request",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"review_note\": \"Missing receipt.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/payment-requests/{{payment_request_id}}/rejection",
              "host": ["{{base_url}}"],
              "path": ["api", "payment-requests", "{{payment_request_id}}", "rejection"]
            }
          }
        }
      ]
    }
  ]
}
